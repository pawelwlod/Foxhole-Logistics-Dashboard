# Database Configuration
DATABASE_URL=postgresql+asyncpg://loginet:loginet@localhost:5432/loginet
DATABASE_URL_SYNC=postgresql://loginet:loginet@localhost:5432/loginet

# Redis
REDIS_URL=redis://redis:6379/0

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback

# Application Settings
ENV=development
DEBUG=true
SECRET_KEY=loginet-key

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30